# Copy to .env and fill values

PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5174

# MongoDB connection string
MONGO_URL=mongodb://127.0.0.1:27017/zillit_catering

# JWT signing secret (change in production)
JWT_SECRET=change-me-to-a-long-random-string

# AES-256-CBC key — must be exactly 32 UTF-8 bytes (not base64-decoded).
# Defaults match the iOS dev environment so the iOS app and this backend
# interoperate out of the box.
AES_KEY=Yz2eI81ZLzCxJwf7BjTsMjyx-_PH5op=
AES_IV=Brxd-7fAiRQFYz2e

# Allow requests with stale moduledata timestamps up to this many ms old
MODULEDATA_MAX_SKEW_MS=300000
